<LessonProgressScreen>:
    name: "lesson_progress"

    Image:
        source: app.subject_wallpaper
        allow_stretch: True
        keep_ratio: False
        size_hint: 1, 1
        pos_hint: {"x": 0, "y": 0}

    MDBoxLayout:
        orientation: "vertical"

        # ================= Header =================
        MDBoxLayout:
            size_hint_y: None
            height: "60dp"
            padding: 10
            md_bg_color: 0.1, 0.6, 0.9, 1

            MDLabel:
                id: lesson_title
                text: ""
                font_name: "C:/Windows/Fonts/seguiemj.ttf"
                theme_text_color: "Custom"
                text_color: 1, 1, 0.95, 1
                halign: "center"
                font_style: "H6"

        # ================= Subtopic Progress =================
        MDBoxLayout:
            size_hint_y: None
            height: "40dp"
            padding: 10

            MDLabel:
                id: progress_label
                text: ""
                font_name: "C:/Windows/Fonts/seguiemj.ttf"
                theme_text_color: "Custom"
                text_color: 0.1, 0.6, 0.9, 1
                halign: "center"

        # ================= Scrollable Content =================
        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: 20
                spacing: 20
                size_hint_y: None
                height: self.minimum_height

                MDLabel:
                    id: subtopic_title
                    text: ""
                    font_name: "C:/Windows/Fonts/seguiemj.ttf"
                    font_style: "H6"
                    theme_text_color: "Custom"
                    text_color: 0.1, 0.6, 0.9, 1
                    size_hint_y: None
                    height: self.texture_size[1]

                Image:
                    id: lesson_image
                    size_hint_y: None
                    height: "220dp"
                    opacity: 0

                MDLabel:
                    id: lesson_text
                    text: ""
                    font_name: "C:/Windows/Fonts/seguiemj.ttf"
                    font_style: "Body1"
                    theme_text_color: "Custom"
                    text_color: 0, 0, 0, 1
                    text_size: self.width, None
                    size_hint_y: None
                    height: self.texture_size[1]

        # ================= Navigation Footer =================
        MDBoxLayout:
            size_hint_y: None
            height: "50dp"
            padding: 10
            spacing: 10

            MDFlatButton:
                text: "⬅ Back"
                font_name: "C:/Windows/Fonts/seguiemj.ttf"
                text_color: 1, 1, 0.95, 1
                on_release: root.prev_subtopic()

            MDRaisedButton:
                text: "Next ▶"
                font_name: "C:/Windows/Fonts/seguiemj.ttf"
                md_bg_color: 0.1, 0.6, 0.9, 1
                on_release: root.next_subtopic()
