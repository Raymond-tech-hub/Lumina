<TasksScreen>:
    name: 'tasks'

    MDBoxLayout:
        orientation: "vertical"

        # ================= HEADER =================
        FloatLayout:
            MDBoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(80)
                padding: dp(10)
                spacing: dp(20)
                pos_hint: {"top": 1}
                md_bg_color: app.theme_cls.primary_dark

                # Logo
                FitImage:
                    id: logo
                    source: app.app_logo2
                    size_hint: None, None
                    size: dp(50), dp(50)
                    radius: [dp(25)]

                # App Name
                MDLabel:
                    text: "Lumina"
                    font_size: dp(36)
                    bold: True
                    color: 0.5, 0.93, 1, 1
                    valign: "middle"

        # ================= SCROLLABLE BODY =================
        ScrollView:
            do_scroll_x: False
            size_hint_y: 1

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                padding: dp(12)
                spacing: dp(12)

                # ========== CURRENT TASK ==========
                MDBoxLayout:
                    id: current_task_box
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(120)
                    padding: dp(12)
                    spacing: dp(8)

                    MDLabel:
                        text: "Current Task"
                        font_style: "H6"
                        size_hint_y: None
                        height: self.texture_size[1]

                    MDCard:
                        id: current_task_card
                        size_hint_y: None
                        height: dp(80)
                        radius: dp(12)
                        elevation: 3
                        padding: dp(12)

                        MDBoxLayout:
                            orientation: "horizontal"
                            spacing: dp(20)

                            MDLabel:
                                id: task_description
                                text: "Task description here"
                                font_style: "Subtitle1"
                                valign: "middle"

                            MDFillRoundFlatButton:
                                id: claim_button
                                text: "Claim"
                                on_release: root.claim_task()
                                md_bg_color: 0.5, 0.5, 0.5, 1  # Default gray

                # ========== DAILY TASKS PLACEHOLDER ==========
                MDBoxLayout:
                    id: daily_tasks
                    orientation: "vertical"
                    size_hint_y: None
                    adaptive_height: True
                    padding: dp(12)
                    spacing: dp(12)

                    ScrollView:
                        do_scroll_x: False
                        MDBoxLayout:
                            orientation: "vertical"
                            adaptive_height: True
                            spacing: dp(8)

                            # Example daily task card
                            MDCard:
                                size_hint_y: None
                                height: dp(80)
                                radius: dp(12)
                                elevation: 2
                                padding: dp(12)


        # ================= FOOTER =================
        MDBoxLayout:
            id: footer
            orientation: "horizontal"
            size_hint_y: None
            height: dp(80)
            padding: [dp(60), dp(10), dp(20), dp(10)]
            spacing: dp(100)
            pos_hint: {"center_x": 0.5}
            md_bg_color: app.theme_cls.primary_dark

            ImageButton:
                source: app.home_icon
                size_hint: None, None
                size: dp(50), dp(50)
                on_release: root.go_home()  

            ImageButton:
                source: app.task_icon
                size_hint: None, None
                size: dp(50), dp(50)
                on_release: root.go_tasks()  

            ImageButton:
                source: app.leaderboard_icon
                size_hint: None, None
                size: dp(50), dp(50)
                on_release: root.go_leaderboard()  

            ImageButton:
                source: app.quiz_icon
                size_hint: None, None
                size: dp(50), dp(50)
                on_release: root.go_quiz()

            ImageButton:
                source: app.profile_icon
                size_hint: None, None
                size: dp(50), dp(50)
                on_release: root.go_profile() 