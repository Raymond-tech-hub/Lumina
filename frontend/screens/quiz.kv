<QuizScreen>:
    name: 'quiz'   
    Image:
        source: app.mini_quest_wallpaper
        allow_stretch: True
        keep_ratio: False
        size_hint: 1, 1
        pos_hint: {"x": 0, "y": 0}
           
    # ================= HEADER =================
    FloatLayout:
        MDBoxLayout:
            orientation: "horizontal"    # horizontal elements
            size_hint_y: None            # fixed height
            height: dp(80)               # header height
            padding: dp(1)
            spacing: dp(20)              # space between items
            pos_hint: {"top": 1}
            md_bg_color: app.theme_cls.primary_dark

            # Logo
            FitImage:
                id: logo
                source: app.app_logo2
                size_hint: None, None
                size: dp(50), dp(50)
                radius: [dp(25)]   # half of width/height → makes it fully round

            # App Name
            MDLabel:
                text: "Lumina"
                font_size: dp(36)
                bold: True
                color: 0.5, 0.93, 1, 1
                valign: "middle"
    # ================= MIDDLE_SECTOR =================
    FloatLayout:
        BoxLayout:
            id: middle_sector
            orientation: "vertical"
            spacing: dp(10)
            padding: dp(10)
            pos_hint: {"top": 0.95}  # slightly below header
            size_hint_y: 0.8        # takes most of the vertical space

            MDLabel:
                text: "Daily Quiz"
                halign: "center"
                theme_text_color: "Primary"
                font_style: "H5"

            # ---------------- SCROLLABLE QUIZ CONTAINER ----------------
            ScrollView:
                do_scroll_x: False
                do_scroll_y: True

                BoxLayout:
                    id: quiz_container   
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(10)
                    padding: dp(5)


    # ================= FOOTER =================
    MDBoxLayout:
        id: footer
        orientation: "horizontal"
        size_hint_y: None
        height: dp(80)
        padding: [dp(60), dp(10), dp(20), dp(10)] # left, top, right, bottom
        spacing: dp(100)
        md_bg_color: 0, 0, 0, 0.2   # optional translucent background
        adaptive_width: True
        pos_hint: {"center_x": 0.5}
        md_bg_color: app.theme_cls.primary_dark


        ImageButton:
            source: app.home_icon
            size_hint: None, None
            size: dp(50), dp(50)
            on_release: root.go_home()  

        ImageButton:
            source: app.task_icon
            size_hint: None, None
            size: dp(50), dp(50)
            on_release: root.go_tasks()  

        ImageButton:
            source: app.leaderboard_icon
            size_hint: None, None
            size: dp(50), dp(50)
            on_release: root.go_leaderboard()  

        ImageButton:
            source: app.profile_icon
            size_hint: None, None
            size: dp(50), dp(50)
            on_release: root.go_profile() 

        ImageButton:
            source: app.quiz_icon
            size_hint: None, None
            size: dp(50), dp(50)
            on_release: root.go_quiz()